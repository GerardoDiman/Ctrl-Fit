---
import Layout from '../../layouts/Layout.astro';
import { ManagementDashboard } from '@/components/management/ManagementDashboard';
---

<script>
	import { supabase } from '@/lib/supabase';
	
	// Check auth state and role
	async function checkAccess() {
		const { data: { session } } = await supabase.auth.getSession();
		
		if (!session) {
			window.location.href = '/auth';
			return;
		}

		const { data: profile } = await supabase
			.from('profiles')
			.select('role')
			.eq('id', session.user.id)
			.single();

		if (!profile || (profile.role !== 'trainer' && profile.role !== 'owner')) {
			window.location.href = '/dashboard';
		}
	}

	checkAccess();

	// Listen for auth changes
	supabase.auth.onAuthStateChange((event, session) => {
		if (event === 'SIGNED_OUT' || !session) {
			window.location.href = '/auth';
		}
	});
</script>

<Layout title="Gestión General | Ctrl + Fit">
	<div class="container mx-auto px-4 max-w-6xl">
		<header class="mb-8">
			<h1 class="text-3xl font-bold font-heading">Gestión General</h1>
			<p class="text-gray-400">Administra tus alumnos, planificaciones de rutinas y catálogo de ejercicios.</p>
		</header>

		<ManagementDashboard client:load />
	</div>
</Layout>

---
import Layout from '../../layouts/Layout.astro';
import { WorkoutStats } from '@/components/dashboard/WorkoutStats';
import { RoutineList } from '@/components/dashboard/RoutineList';
import { StudentViewCalendar } from '@/components/dashboard/StudentViewCalendar';
import { Card, CardHeader, CardTitle, CardContent, CardDescription } from '@/components/ui/card';
---

<script>
	import { supabase } from '@/lib/supabase';
	
	// Check auth state
	supabase.auth.getSession().then(({ data: { session } }) => {
		if (!session) {
			window.location.href = '/auth';
		}
	});

	// Listen for auth changes (e.g. if user logs out from another tab)
	supabase.auth.onAuthStateChange((event, session) => {
		if (event === 'SIGNED_OUT' || !session) {
			window.location.href = '/auth';
		}
	});
</script>

<Layout title="Dashboard | Ctrl + Fit">
	<div class="container mx-auto px-4 max-w-5xl">
		<header class="mb-8">
			<h1 class="text-3xl font-bold font-heading text-white">Tu Rendimiento</h1>
			<p class="text-gray-400">Resumen de la semana actual y planificación.</p>
		</header>

		<!-- Stats Grid Dinámico -->
		<WorkoutStats client:load />

		<!-- Calendario de Planificación -->
		<section class="mb-12">
			<header class="mb-4 flex justify-between items-center border-b border-white/5 pb-2">
				<h2 class="text-xl font-bold font-heading text-primary">Planificación de Entrenamientos</h2>
				<a href="/dashboard/history" class="text-xs font-bold text-gray-400 hover:text-primary transition-colors flex items-center gap-1">
					Ver Historial y Agenda →
				</a>
			</header>
			<StudentViewCalendar client:load />
		</section>

		<!-- Mis Rutinas -->
		<section>
			<header class="mb-4">
				<h2 class="text-xl font-bold font-heading text-white border-b border-white/5 pb-2">Mis Rutinas Guardadas</h2>
			</header>
			<RoutineList client:load />
		</section>
	</div>
</Layout>


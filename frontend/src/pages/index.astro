---
import Layout from '../layouts/Layout.astro';
import { Button } from '@/components/ui/button';
import { Dumbbell } from 'lucide-react';
---

<Layout title="Inicio | Ctrl + Fit">
	<div class="container mx-auto px-4 flex flex-col items-center justify-center min-h-[70vh] text-center">
		<div class="mb-6 p-4 rounded-full bg-[var(--color-card)] border border-[var(--color-border)]">
			<Dumbbell className="h-16 w-16 text-[var(--color-primary)]" />
		</div>
		<h1 class="text-5xl md:text-7xl font-bold font-heading mb-6 tracking-tight">
			FORJA TU <br />
			<span class="text-[var(--color-primary)]">MEJOR VERSIÓN</span>
		</h1>
		<p class="text-lg md:text-xl text-gray-400 font-body max-w-2xl mb-10">
			El laboratorio de alto rendimiento en tu bolsillo. Seguimiento de rutinas, métricas precisas y rutinas generadas para atletas serios.
		</p>
		<div class="flex items-center gap-4">
			<a href="/auth">
				<Button size="lg" className="text-lg">Comenzar Ahora</Button>
			</a>
			<a href="/dashboard">
				<Button variant="secondary" size="lg" className="text-lg">Ver Dashboard</Button>
			</a>
		</div>
	</div>
</Layout>
